{
  "name": "brave-variations",
  "version": "0.0.1",
  "description": "Brave Variations",
  "scripts": {
    "build": "pnpm build:proto && pnpm build:web",
    "build:proto": "tsx src/scripts/generate_proto_ts.ts",
    "build:web": "webpack -c src/web/webpack.config.js --mode=production",
    "clean": "tsx src/scripts/clean.ts",
    "lint": "tsx src/scripts/lint.ts",
    "postinstall": "pnpm typecheck:scripts && pnpm build:proto",
    "seed_tools": "tsx src/seed_tools/seed_tools.ts",
    "serve:dev": "webpack serve -c src/web/webpack.config.js --hot --mode=development",
    "test": "node --import tsx --test **/*.test.ts",
    "tracker": "tsx src/finch_tracker/main.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:scripts": "tsc --noEmit --project src/scripts"
  },
  "devDependencies": {
    "@commander-js/extra-typings": "15.0.0",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@protobuf-ts/plugin": "2.11.1",
    "@types/node": "25.9.4",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.62.0",
    "commander": "15.0.0",
    "css-loader": "7.1.4",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-licenses": "2.0.0",
    "file-loader": "6.2.0",
    "globals": "17.7.0",
    "prettier": "3.8.4",
    "prettier-plugin-multiline-arrays": "4.1.9",
    "prettier-plugin-organize-imports": "4.3.0",
    "style-loader": "4.0.0",
    "ts-loader": "9.6.2",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "webpack": "5.107.2",
    "webpack-cli": "7.0.3",
    "webpack-dev-server": "5.2.5"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=22.0.0",
      "onFail": "error"
    },
    "packageManager": {
      "name": "pnpm",
      "version": ">=10.29.2",
      "onFail": "error"
    }
  },
  "type": "commonjs",
  "license": "MPL-2.0",
  "moduleResolution": "node",
  "dependencies": {
    "@protobuf-ts/runtime": "2.11.1",
    "json5": "2.2.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router": "8.0.1"
  }
}
